# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored — never commit the secret.

# From your GitHub OAuth App (https://github.com/settings/developers).
# Register it with the callback URL shown in the `oauth_callback_url` output.
github_client_id     = "Iv1_xxxxxxxxxxxxxxxx"
github_client_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

region   = "eu-west-1"
key_name = ""          # your EC2 key pair name for SSH (optional)
ssh_cidr = "0.0.0.0/0" # tighten to YOUR_IP/32

# DNS managed externally (Namecheap): after apply, point this name at the Elastic IP
# (see the dns_record_to_create output). Clear it to use the raw IP.
domain_name = "pr-dashboard.gr-oss.io"

author = "Ivan Pavlovic"
